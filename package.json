{
  "name": "python-function-analyzer",
  "displayName": "Python Function Analyzer",
  "description": "Analyze Python functions by file and display in a panel",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/*.py"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pythonFunctionAnalyzer.analyzeFunctions",
        "title": "Analyze Python Functions",
        "category": "Python Function Analyzer"
      },
      {
        "command": "pythonFunctionAnalyzer.refreshAnalysis",
        "title": "Refresh Analysis",
        "category": "Python Function Analyzer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "pythonFunctionAnalyzer.analyzeFunctions",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "pythonFunctionAnalyzer.analyzeFunctions",
          "when": "workspaceHasAtLeastOnePythonFile"
        },
        {
          "command": "pythonFunctionAnalyzer.refreshAnalysis",
          "when": "workspaceHasAtLeastOnePythonFile"
        }
      ]
    },
    "configuration": {
      "title": "Python Function Analyzer",
      "properties": {
        "pythonFunctionAnalyzer.excludePatterns": {
          "type": "array",
          "default": ["**/node_modules/**", "**/__pycache__/**", "**/venv/**", "**/env/**"],
          "description": "Patterns to exclude from analysis"
        },
        "pythonFunctionAnalyzer.showNestedFunctions": {
          "type": "boolean",
          "default": false,
          "description": "Include nested functions in analysis"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^9.34.0",
    "typescript": "^4.9.4"
  }
}